{
  "name": "notion-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:prod": "dotenv -e .env.production.local -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:check": "eslint .",
    "format": "prettier --write app components convex hooks lib scripts eslint-rules .github .ai \"*.{json,mjs,ts}\"",
    "format:check": "prettier --check .github eslint-rules eslint.config.mjs jest.config.ts lib/blocknote-content.ts lib/coworker-message-ui.tsx lib/coworker-message-ui.test.ts lib/design-tokens.ts lib/design-tokens.test.ts lib/tree-indent-class.ts lib/tree-indent-class.test.ts lib/blocknote-content.test.ts .ai/CONTRIBUTING.md .ai/INSTRUCTIONS.md .ai/commands/create-pr.md .ai/commands/commit.md .ai/skills/code-quality-checklist .ai/skills/feature-workflow .ai/skills/eslint-self-heal team-os/engineering/CLAUDE.md team-os/engineering/reference-implementations.md",
    "format:check:repo": "prettier --check app components convex hooks lib scripts eslint-rules .github .ai \"*.{json,mjs,ts}\"",
    "test:eslint-rules": "node eslint-rules/noted/no-hardcoded-color.test.mjs && node eslint-rules/noted/no-inline-style.test.mjs",
    "type:check": "tsc --noEmit",
    "seed:convex:plan": "node scripts/seed-convex.mjs",
    "seed:convex": "node scripts/seed-convex.mjs --run --yes",
    "seed:convex:clean": "node scripts/seed-convex.mjs --clean --yes",
    "seed:amplitude:plan": "node scripts/seed-amplitude.mjs",
    "seed:amplitude": "node scripts/seed-amplitude.mjs --apply",
    "sync-ai": "node scripts/sync-ai.mjs",
    "design:lint": "npx --yes @google/design.md lint DESIGN.md",
    "postinstall": "node scripts/sync-ai.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/google": "^3.0.13",
    "@ai-sdk/openai": "^3.0.19",
    "@ai-sdk/react": "^3.0.51",
    "@amplitude/analytics-browser": "^2.42.1",
    "@blocknote/core": "^0.46.1",
    "@blocknote/mantine": "^0.46.1",
    "@blocknote/react": "^0.46.1",
    "@blocknote/xl-ai": "^0.46.1",
    "@clerk/nextjs": "^6.36.10",
    "@edgestore/react": "^0.3.3",
    "@edgestore/server": "^0.3.3",
    "@eslint/eslintrc": "^3.3.3",
    "@launchdarkly/node-server-sdk": "^9.11.2",
    "@mantine/core": "^8.3.13",
    "@mantine/hooks": "^8.3.13",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tiptap/core": "^3.17.0",
    "@tiptap/extensions": "^3.17.0",
    "@types/node": "^20",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "ai": "^6.0.49",
    "autoprefixer": "^10.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^0.2.1",
    "convex": "^1.20.0",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.7.10",
    "lucide-react": "^0.315.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "node-emoji": "^2.2.0",
    "postcss": "^8",
    "random-emoji": "^1.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.2.3",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.3",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.2",
    "sonner": "^1.3.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "unique-names-generator": "^4.7.1",
    "usehooks-ts": "^2.10.0",
    "zod": "^3.24.2",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3"
  }
}
